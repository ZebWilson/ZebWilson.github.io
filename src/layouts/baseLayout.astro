---
// Base layout: centralize <head>, Nav, and main structure.
const { title = "Zeb", description = "Personal site by Zeb" } = Astro.props;
import Nav from "../components/Nav.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <slot name="head" />
    <!-- KaTeX styles for math rendered by rehype-katex -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.25/dist/katex.min.css"
    />
    <!-- Load Lexend for text and JetBrains Mono for code -->
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <style>
      /* Minimal global layout styles */
      :root {
        color-scheme: light dark;
      }
      body {
        /* Prefer Lexend (sans). Fall back to common system sans-serif families */
        font-family:
          "Lexend",
          system-ui,
          -apple-system,
          "Segoe UI",
          Roboto,
          "Helvetica Neue",
          Arial,
          sans-serif;
        margin: 0;
        background: #eae8e8;
        color: #0f172a;
      }
      code {
        /* Prefer JetBrains Mono, then platform monospace fallbacks */
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo,
          Monaco, "Roboto Mono", "Courier New", monospace;
        margin: 0;
        background: #eae8e8;
        color: #2b4584;
      }
      main {
        padding: 24px;
        max-width: 900px;
        margin: 0 auto;
      }
      nav a {
        color: inherit;
      }
    </style>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
  </body>
</html>
